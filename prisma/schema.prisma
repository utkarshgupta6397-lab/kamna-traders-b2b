generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      String             @id @default(cuid())
  name                    String
  mobile                  String             @unique
  role                    String             @default("STAFF")
  active                  Boolean            @default(true)
  pin                     String?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  
  // Permissions Matrix
  canViewCatalog          Boolean            @default(true)
  canViewCarts            Boolean            @default(true)
  canManageCarts          Boolean            @default(false)
  canCreateOrder          Boolean            @default(true)
  canViewOrders           Boolean            @default(true)
  canViewInventory        Boolean            @default(true)
  canEditInventory        Boolean            @default(false)
  canViewInventoryHistory Boolean            @default(false)
  canViewUsers            Boolean            @default(false)
  canEditUsers            Boolean            @default(false)
  canViewReports          Boolean            @default(false)
  canAccessSettings       Boolean            @default(false)
  canSyncSkus             Boolean            @default(false)
  canHardReset            Boolean            @default(false)
  canDebugZoho            Boolean            @default(false)

  sessions         ActiveSession[]
  carts            Cart[]
  inventoryHistory InventoryHistory[]
}

model Warehouse {
  id               String               @id @default(cuid())
  name             String
  address          String?
  active           Boolean              @default(true)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  carts            Cart[]
  inventoryHistory InventoryHistory[]
  inventory        WarehouseInventory[]
}

model Brand {
  id        String   @id @default(cuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  skus      Sku[]
}

model Category {
  id        String     @id @default(cuid())
  name      String     @unique
  active    Boolean    @default(true)
  parentId  String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  parent    Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children  Category[] @relation("SubCategories")
  skus      Sku[]
}

model Sku {
  id             String               @id
  name           String
  brandId        String?
  unit           String?
  moq            Int                  @default(1)
  stepQty        Int                  @default(1)
  price          Float                @default(0.0)
  gstPercent     Float                @default(0.0)
  hsnCode        String?
  description    String?
  caseSize       Int                  @default(1)
  lastSyncedAt   DateTime?
  zohoBookItemId String?              @unique // String to prevent JS precision corruption
  zohoBooksId2   String?
  categoryId     String?
  isActive       Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  cartItems      CartItem[]
  brand          Brand?               @relation(fields: [brandId], references: [id])
  category       Category?            @relation(fields: [categoryId], references: [id])
  inventory      WarehouseInventory[]

  @@index([categoryId])
  @@index([brandId])
  @@index([createdAt])
  @@index([zohoBookItemId])
  @@index([zohoBooksId2])
}

model WarehouseInventory {
  id          String    @id @default(cuid())
  warehouseId String
  skuId       String
  qty         Int       @default(0)
  isOos       Boolean   @default(false)
  zone        String?
  updatedAt   DateTime  @updatedAt
  sku         Sku       @relation(fields: [skuId], references: [id])
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([warehouseId, skuId])
}

model Cart {
  id                   String     @id
  warehouseId          String
  customerName         String
  notes                String?
  staffId              String
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  dispatchSlipNumber   String?    @unique
  zohoSalesorderId     String?
  zohoSalesorderNumber String?
  zohoSyncStatus       String?    @default("PENDING")
  zohoSyncStep         String?    @default("INITIATED")
  zohoSyncError        String?
  zohoLastSyncAt       DateTime?
  zohoResponseTimeMs   Int?
  zohoPayload          Json?
  zohoResponse         Json?
  zohoExecutionTrace   Json?
  deletedAt            DateTime?
  staff                User       @relation(fields: [staffId], references: [id])
  warehouse            Warehouse  @relation(fields: [warehouseId], references: [id])
  items                CartItem[]
}

model CartItem {
  id          String @id @default(cuid())
  cartId      String
  skuId       String
  qty         Int
  originalQty Int?
  cart        Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)
  sku         Sku    @relation(fields: [skuId], references: [id])
}

model CustomerLead {
  id            String   @id @default(cuid())
  cartId        String?
  items         String
  sessionId     String?
  deviceMeta    String?
  sourceChannel String   @default("whatsapp")
  createdAt     DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  details   String?
  createdAt DateTime @default(now())
}

model DispatchSequence {
  date     String @id
  sequence Int    @default(0)
}

model SyncLock {
  id        String   @id @default("singleton")
  name      String   @unique
  isLocked  Boolean  @default(false)
  lockedAt  DateTime?
  lockedBy  String?
  updatedAt DateTime @updatedAt
}

model SkuSyncLog {
  id            String    @id @default(cuid())
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  trigger       String    @default("CRON") // "CRON" | "USER"
  syncLimit     Int?      @default(0)
  totalReceived Int       @default(0)
  processedCount Int      @default(0)
  createdCount  Int       @default(0)
  updatedCount  Int       @default(0)
  skippedCount  Int       @default(0)
  failedCount   Int       @default(0)
  metadata      Json?     // Raw API request/response metadata
  logs          Json?     // Backwards compatibility for errors
  executionTrace Json?    // Detailed per-SKU logs
}

model SkuIdentityRegistry {
  id               String   @id @default(cuid())
  skuId            String   @unique
  zohoBookItemId   String   @unique
  firstSeenAt      DateTime @default(now())
  lastSeenAt       DateTime @updatedAt
  isActive         Boolean  @default(true)
  syncGeneration   Int      @default(1)
  
  @@index([zohoBookItemId])
  @@index([skuId])
}

model InventoryHistory {
  id          String    @id @default(cuid())
  warehouseId String
  skuId       String
  productName String
  beforeQty   Int
  afterQty    Int
  qtyChange   Int
  remarks     String
  createdBy   String
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [createdBy], references: [id])
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  @@index([warehouseId])
  @@index([skuId])
  @@index([createdAt])
}

model ZohoToken {
  id           String   @id @default("singleton")
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  updatedAt    DateTime @updatedAt
}

model ActiveSession {
  id           String   @id @default(cuid())
  userId       String
  sessionToken String   @unique
  deviceType   String
  deviceName   String?
  userAgent    String?
  ipAddress    String?
  lastSeenAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionToken])
  @@index([lastSeenAt])
  @@index([userId, deviceType])
}
