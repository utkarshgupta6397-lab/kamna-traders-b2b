generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  mobile    String   @unique
  role      String   @default("STAFF")
  active    Boolean  @default(true)
  pin       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  carts     Cart[]
  inventoryHistory InventoryHistory[]
}

model Warehouse {
  id        String               @id @default(cuid())
  name      String
  address   String?
  active    Boolean              @default(true)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  carts     Cart[]
  inventory WarehouseInventory[]
  inventoryHistory InventoryHistory[]
}

model Brand {
  id        String   @id @default(cuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  skus      Sku[]
}

model Category {
  id        String     @id @default(cuid())
  name      String
  active    Boolean    @default(true)
  parentId  String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  parent    Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children  Category[] @relation("SubCategories")
  skus      Sku[]
}

model Sku {
  id              String               @id
  name            String
  brandId         String?
  unit            String?
  moq             Int                  @default(1)
  stepQty         Int                  @default(1)
  price           Float                @default(0.0)
  gstPercent      Float                @default(0.0)
  hsnCode         String?
  description     String?
  caseSize        Int                  @default(1)
  lastSyncedAt    DateTime?
  zohoBookItemId  BigInt?
  categoryId      String?
  isActive        Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  cartItems       CartItem[]
  brand           Brand?               @relation(fields: [brandId], references: [id])
  category        Category?            @relation(fields: [categoryId], references: [id])
  inventory       WarehouseInventory[]

  @@index([categoryId])
  @@index([brandId])
  @@index([createdAt])
  @@index([zohoBookItemId])
}

model WarehouseInventory {
  id          String    @id @default(cuid())
  warehouseId String
  skuId       String
  qty         Int       @default(0)
  isOos       Boolean   @default(false)
  zone        String?
  updatedAt   DateTime  @updatedAt
  sku         Sku       @relation(fields: [skuId], references: [id], onUpdate: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([warehouseId, skuId])
}

model Cart {
  id                 String     @id
  warehouseId        String
  customerName       String
  notes              String?
  staffId            String
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  dispatchSlipNumber String?    @unique
  staff              User       @relation(fields: [staffId], references: [id])
  warehouse          Warehouse  @relation(fields: [warehouseId], references: [id])
  items              CartItem[]
}

model CartItem {
  id     String @id @default(cuid())
  cartId String
  skuId  String
  qty    Int
  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)
  sku    Sku    @relation(fields: [skuId], references: [id], onUpdate: Cascade)
}

model CustomerLead {
  id            String   @id @default(cuid())
  cartId        String?
  items         String
  sessionId     String?
  deviceMeta    String?
  sourceChannel String   @default("whatsapp")
  createdAt     DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  details   String?
  createdAt DateTime @default(now())
}

model DispatchSequence {
  date     String @id
  sequence Int    @default(0)
}

model SkuSyncLog {
  id            String    @id @default(cuid())
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  totalReceived Int       @default(0)
  createdCount  Int       @default(0)
  updatedCount  Int       @default(0)
  failedCount   Int       @default(0)
  logs          Json?
}

model InventoryHistory {
  id          String    @id @default(cuid())
  warehouseId String
  skuId       String
  productName String
  beforeQty   Int
  afterQty    Int
  qtyChange   Int
  remarks     String
  createdBy   String
  createdAt   DateTime  @default(now())

  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  user        User      @relation(fields: [createdBy], references: [id])

  @@index([warehouseId])
  @@index([skuId])
  @@index([createdAt])
}

